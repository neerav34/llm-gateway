# Copy this file to .env and fill in your keys. Never commit .env.

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter fallback provider (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Upstash Redis REST credentials (https://console.upstash.com) — cache + rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
